# T2 Travel Terminal environment variables
# Copy this file to .env and fill in your actual values.

# PostgreSQL connection string (required)
# Example for a managed database:
#   DATABASE_URL=postgres://user:password@your-db-host:5432/t2_db
# Example for local development:
#   DATABASE_URL=postgres://postgres:postgres@localhost:5432/t2_db?sslmode=disable
DATABASE_URL=

# Secret used to sign JWT access tokens (required)
# Generate with: openssl rand -base64 32
JWT_SECRET=

# Server bind address (optional, defaults to :8080)
SERVER_ADDR=:8080

# Log level: debug, info, warn, error (optional, defaults to info)
LOG_LEVEL=info

# SMTP configuration for automated emails (required for email verification)
# Gmail example (recommended):
#   1. Enable 2-step verification on your Google account.
#   2. Generate an App Password at https://myaccount.google.com/apppasswords
#   3. Use the 16-character App Password below (remove spaces).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=yourname@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=yourname@gmail.com
SMTP_FROM_NAME=T2 Travel Terminal

# SMTP authentication method: LOGIN (default, for Gmail) or PLAIN
SMTP_AUTH_METHOD=LOGIN

# Base URL used in verification email links (optional, defaults to http://localhost:8080)
EMAIL_VERIFICATION_BASE_URL=http://localhost:8080

# Set to true only for local testing with self-signed SMTP certificates (not recommended for production)
SMTP_INSECURE=false

# Built-in third-party hub providers
# Used by /api/v1/hub/skills/ticketmaster/search-events
TICKETMASTER_API_KEY=
